{
  "version": "0.6.0",
  "name": "babylonpress-ktx2-encoder",
  "description": "KTX2(.ktx2) encoder for browser and Node applications",
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "import": "./dist/node/index.js",
        "types": "./types/node/index.d.ts"
      },
      "default": {
        "import": "./dist/web/index.js",
        "types": "./types/web/index.d.ts"
      }
    },
    "./gltf-transform": {
      "import": "./dist/gltf-transform/index.js",
      "types": "./types/gltf-transform/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eldinor/ktx2-encoder.git"
  },
  "homepage": "https://github.com/eldinor/ktx2-encoder#readme",
  "bugs": {
    "url": "https://github.com/eldinor/ktx2-encoder/issues"
  },
  "author": {
    "name": "eldinor",
    "email": "eldinor@gmail.com"
  },
  "contributors": [
    {
      "name": "Hu Song",
      "email": "gz65555@gmail.com",
      "url": "https://github.com/gz65555/ktx2-encoder"
    }
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "watch": "tsc -p tsconfig.json --watch",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-basis.mjs",
    "test": "npm run test:node",
    "test:node": "vitest run ./test/encoderShared.test.ts ./test/node.test.ts ./test/repeat.node.test.ts ./test/gltf-transform.node.test.ts",
    "test:web": "vitest run --reporter=dot --browser.enabled --browser.name=chrome ./test/web.smoke.test.ts",
    "test:coverage": "vitest run --coverage ./test/encoderShared.test.ts ./test/node.test.ts ./test/repeat.node.test.ts ./test/gltf-transform.node.test.ts",
    "test:gltf": "vitest run ./test/gltf-transform.node.test.ts",
    "test:gltf:web": "vitest run --reporter=dot --browser.enabled --browser.name=chrome ./test/gltf-transform.web.smoke.test.ts",
    "release": "npm version patch"
  },
  "keywords": [
    "ktx",
    "ktx2",
    "basis",
    "texture",
    "encoder",
    "webgl",
    "webgpu"
  ],
  "files": [
    "types",
    "dist"
  ],
  "devDependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "@types/node": "^20.17.16",
    "@vitest/browser": "^4.0.8",
    "@vitest/browser-webdriverio": "^4.0.8",
    "@vitest/coverage-v8": "^4.0.8",
    "prettier": "^2.8.8",
    "sharp": "^0.33.5",
    "typescript": "~5.6.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.8",
    "webdriverio": "^9.7.1"
  },
  "dependencies": {
    "ktx-parse": "^0.7.1"
  }
}
