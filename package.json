{
  "version": "0.5.1",
  "name": "ktx2-encoder",
  "description": "KTX2(.ktx2) encoder for browser applications",
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "import": "./dist/node/index.js",
        "types": "./types/node/index.d.ts"
      },
      "default": {
        "import": "./dist/web/index.js",
        "types": "./types/web/index.d.ts"
      }
    },
    "./gltf-transform": {
      "import": "./dist/gltf-transform/index.js",
      "types": "./types/gltf-transform/index.d.ts"
    }
  },
  "repository": "github:gz65555/ktx2-encoder",
  "author": {
    "name": "Hu Song",
    "email": "gz65555@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "watch": "tsc -p tsconfig.json --watch",
    "build": "tsc -p tsconfig.json && node ./scripts/copy-basis.mjs",
    "test": "npm run test:node",
    "test:node": "vitest run ./test/node.test.ts",
    "test:gltf": "vitest run ./test/gltf-transform.node.test.ts",
    "release": "bumpp"
  },
  "keywords": [
    "ktx",
    "ktx2",
    "basis",
    "texture",
    "encoder",
    "webgl",
    "webgpu"
  ],
  "files": [
    "types",
    "dist"
  ],
  "devDependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "@types/node": "^20.17.16",
    "@webgpu/types": "^0.1.53",
    "bumpp": "^9.11.1",
    "prettier": "^2.8.8",
    "sharp": "^0.33.5",
    "typescript": "~5.6.3",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ktx-parse": "^0.7.1"
  }
}
